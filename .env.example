# Backend database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./statsmec.db
REDIS_URL=memory://

# FACEIT API key (REQUIRED for real match data)
# Get yours free at: https://developers.faceit.com
# 1. Sign in with your FACEIT account
# 2. Create an App in App Studio
# 3. Go to API Keys > Create Server-side key
FACEIT_API_KEY=your_faceit_api_key_here

# MongoDB Atlas (optional, used as a rolling cache so we stay within free tier)
# Example: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/
MONGODB_URI=
MONGODB_DB_NAME=statsmec

# Allstar.gg Partner API
# Server-side key should NEVER be exposed to the frontend.
ALLSTAR_SERVER_API_KEY=
# Optional: public key usable in client-side widgets if needed.
ALLSTAR_PUBLIC_API_KEY=

# Optional: Steam API key (limited use)
STEAM_API_KEY=

# Optional: third-party Premier + Faceit ELO endpoint (e.g. api.jakobkristensen.com)
# The first line of the response should be either:
#   "<premier_rating>|<faceit_elo>"  OR  "<faceit_elo> <premier_rating>"
# Recommended output template on api.jakobkristensen.com:
#   {{rating}}|{{elo}}   or   {{elo}} {{rating}}
PMEC_PREMIER_REMOTE_URL=

BACKEND_CORS_ORIGINS=["*"]
