# Backend database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./statsmec.db
REDIS_URL=memory://

# FACEIT API key (REQUIRED for real match data)
# Get yours free at: https://developers.faceit.com
# 1. Sign in with your FACEIT account
# 2. Create an App in App Studio
# 3. Go to API Keys > Create Server-side key
FACEIT_API_KEY=your_faceit_api_key_here

# Optional: Steam API key (limited use)
STEAM_API_KEY=

BACKEND_CORS_ORIGINS=["*"]
