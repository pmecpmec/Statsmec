---
import MainLayout from '../layouts/MainLayout.astro';
import LiveStatus from '../components/LiveStatus.svelte';
import MatchHistory from '../components/MatchHistory.svelte';
import PerformanceChart from '../components/PerformanceChart.svelte';
import WeaponBreakdown from '../components/WeaponBreakdown.svelte';

const API = import.meta.env.PUBLIC_API_URL ?? 'http://127.0.0.1:8000/api/v1';
---

<MainLayout>
  <!-- Hero / Profile -->
  <section id="overview" class="min-h-screen flex items-center pt-24 pb-16">
    <div class="max-w-6xl mx-auto px-5 w-full">
      <div class="flex flex-col lg:flex-row items-center gap-12">
        <!-- Avatar -->
        <div class="relative reveal">
          <img
            src="https://avatars.steamstatic.com/fef49e7fa7e1997310d705b2a6158ff8dc1cdfeb_full.jpg"
            alt="pmec"
            class="w-44 h-44 md:w-52 md:h-52 rounded-full border-4 border-primary-500 object-cover animate-glow"
          />
          <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 bg-primary-600 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">
            LVL 10
          </div>
        </div>

        <!-- Identity -->
        <div class="text-center lg:text-left reveal stagger-1">
          <h1 class="text-5xl md:text-6xl font-extrabold text-gradient mb-3">pmec</h1>
          <div class="mb-4">
            <LiveStatus client:load apiUrl={API} />
          </div>
          <div class="flex flex-wrap gap-3 justify-center lg:justify-start">
            <span class="px-4 py-1.5 rounded-full text-sm font-semibold border border-amber-500/30 bg-amber-500/10 text-amber-400">
              Global Sentinel
            </span>
            <span class="px-4 py-1.5 rounded-full text-sm font-semibold border border-primary-500/30 bg-primary-500/10 text-primary-400">
              ELO 2616
            </span>
            <span class="px-4 py-1.5 rounded-full text-sm font-semibold border border-white/10 bg-white/5 text-zinc-300">
              9,620h played
            </span>
            <span class="px-4 py-1.5 rounded-full text-sm font-semibold border border-white/10 bg-white/5 text-zinc-300">
              1,242 matches
            </span>
          </div>
        </div>

        <!-- Quick Stats -->
        <div class="flex-1 w-full lg:w-auto reveal stagger-2">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <div class="stat-card">
              <span class="text-2xl md:text-3xl font-extrabold text-cs-green">54%</span>
              <span class="text-xs uppercase tracking-wider text-zinc-500">Win Rate</span>
            </div>
            <div class="stat-card">
              <span class="text-2xl md:text-3xl font-extrabold">1.29</span>
              <span class="text-xs uppercase tracking-wider text-zinc-500">K/D</span>
            </div>
            <div class="stat-card">
              <span class="text-2xl md:text-3xl font-extrabold text-amber-400">52.4%</span>
              <span class="text-xs uppercase tracking-wider text-zinc-500">HS %</span>
            </div>
            <div class="stat-card">
              <span class="text-2xl md:text-3xl font-extrabold">671</span>
              <span class="text-xs uppercase tracking-wider text-zinc-500">Wins</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Detail -->
  <section id="stats" class="py-20" style="background: var(--bg-secondary);">
    <div class="max-w-6xl mx-auto px-5">
      <h2 class="section-title reveal">Performance</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="glass-card reveal stagger-1">
          <PerformanceChart client:load apiUrl={API} />
        </div>
        <div class="glass-card reveal stagger-2">
          <WeaponBreakdown client:load apiUrl={API} />
        </div>
      </div>
    </div>
  </section>

  <!-- Settings Section -->
  <section id="settings" class="py-20">
    <div class="max-w-6xl mx-auto px-5">
      <h2 class="section-title reveal">Game Settings</h2>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Mouse -->
        <div class="glass-card reveal stagger-1">
          <h3 class="text-lg font-bold text-primary-400 mb-4 flex items-center gap-2">
            <span class="text-xl">🖱️</span> Mouse
          </h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between"><span class="text-zinc-400">DPI</span><span class="font-semibold">400</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Sensitivity</span><span class="font-semibold">1.3</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">eDPI</span><span class="font-semibold text-primary-400">520</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Zoom Sens</span><span class="font-semibold">1.0</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Polling Rate</span><span class="font-semibold">1000 Hz</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">m_yaw</span><span class="font-semibold font-mono">0.022</span></div>
          </div>
        </div>

        <!-- Video -->
        <div class="glass-card reveal stagger-2">
          <h3 class="text-lg font-bold text-primary-400 mb-4 flex items-center gap-2">
            <span class="text-xl">🖥️</span> Video
          </h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between"><span class="text-zinc-400">Resolution</span><span class="font-semibold">1280x960</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Aspect Ratio</span><span class="font-semibold">4:3 Stretched</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Refresh Rate</span><span class="font-semibold">240 Hz</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Display Mode</span><span class="font-semibold">Fullscreen</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Brightness</span><span class="font-semibold">93%</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">V-Sync</span><span class="font-semibold text-cs-red">Off</span></div>
          </div>
        </div>

        <!-- Crosshair -->
        <div class="glass-card reveal stagger-3">
          <h3 class="text-lg font-bold text-primary-400 mb-4 flex items-center gap-2">
            <span class="text-xl">🎯</span> Crosshair
          </h3>
          <div class="flex items-center justify-center mb-4 p-6 rounded-xl" style="background: rgba(0,0,0,0.4);">
            <div class="relative w-20 h-20 flex items-center justify-center">
              <div class="absolute w-0.5 h-4 bg-green-400 -top-0.5 left-1/2 -translate-x-1/2" style="top:-6px;"></div>
              <div class="absolute w-0.5 h-4 bg-green-400 -bottom-0.5 left-1/2 -translate-x-1/2" style="bottom:-6px;"></div>
              <div class="absolute h-0.5 w-4 bg-green-400 -left-0.5 top-1/2 -translate-y-1/2" style="left:-6px;"></div>
              <div class="absolute h-0.5 w-4 bg-green-400 -right-0.5 top-1/2 -translate-y-1/2" style="right:-6px;"></div>
              <div class="w-1 h-1 rounded-full bg-green-400"></div>
            </div>
          </div>
          <div class="text-center">
            <code class="text-xs text-zinc-400 break-all select-all bg-black/30 px-3 py-1.5 rounded-lg inline-block">
              CSGO-wwZcC-ZUfz2-UVBXb-ftEqF-aAmDA
            </code>
          </div>
        </div>
      </div>

      <!-- Advanced Video + Viewmodel + Launch Options -->
      <div class="grid md:grid-cols-2 gap-6 mt-6">
        <div class="glass-card reveal stagger-4">
          <h3 class="text-lg font-bold text-primary-400 mb-4 flex items-center gap-2">
            <span class="text-xl">⚙️</span> Advanced Video
          </h3>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-zinc-400">Anti-Aliasing</span><span class="font-semibold">4x MSAA</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Shadow Quality</span><span class="font-semibold">High</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Model / Texture</span><span class="font-semibold">Low</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Texture Filtering</span><span class="font-semibold">Anisotropic 4X</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Shader Detail</span><span class="font-semibold">High</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Particle Detail</span><span class="font-semibold">Low</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Ambient Occlusion</span><span class="font-semibold">High</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">HDR</span><span class="font-semibold">Quality</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">FSR</span><span class="font-semibold text-cs-red">Disabled</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">NVIDIA Reflex</span><span class="font-semibold text-cs-green">Enabled + Boost</span></div>
            <div class="flex justify-between"><span class="text-zinc-400">Boost Contrast</span><span class="font-semibold text-cs-red">Disabled</span></div>
          </div>
        </div>

        <div class="glass-card reveal stagger-5">
          <h3 class="text-lg font-bold text-primary-400 mb-4 flex items-center gap-2">
            <span class="text-xl">🔧</span> Config
          </h3>
          <div class="space-y-4">
            <div>
              <span class="text-xs uppercase tracking-wider text-zinc-500 block mb-1">Launch Options</span>
              <code class="text-sm text-zinc-300 bg-black/30 px-3 py-2 rounded-lg block select-all">
                -tickrate 128 -novid +exec autoexec.cfg
              </code>
            </div>
            <div>
              <span class="text-xs uppercase tracking-wider text-zinc-500 block mb-1">Viewmodel</span>
              <code class="text-sm text-zinc-300 bg-black/30 px-3 py-2 rounded-lg block select-all">
                viewmodel_fov 68; viewmodel_offset_x 2.5; viewmodel_offset_z -1.5
              </code>
            </div>
            <div>
              <span class="text-xs uppercase tracking-wider text-zinc-500 block mb-1">HUD</span>
              <code class="text-sm text-zinc-300 bg-black/30 px-3 py-2 rounded-lg block select-all">
                hud_scaling 0.95; cl_hud_color 3; cl_showloadout true
              </code>
            </div>
            <div>
              <span class="text-xs uppercase tracking-wider text-zinc-500 block mb-1">Radar</span>
              <code class="text-sm text-zinc-300 bg-black/30 px-3 py-2 rounded-lg block select-all">
                cl_radar_scale 0.4; cl_radar_always_centered 1; cl_radar_rotate 1
              </code>
            </div>
          </div>
        </div>
      </div>

      <!-- Key Binds -->
      <div class="glass-card mt-6 reveal stagger-6">
        <h3 class="text-lg font-bold text-primary-400 mb-4 flex items-center gap-2">
          <span class="text-xl">⌨️</span> Key Binds
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-2 text-sm">
          <div class="flex justify-between"><span class="text-zinc-400">Jump</span><span class="font-mono font-semibold">Space / MWheel↓</span></div>
          <div class="flex justify-between"><span class="text-zinc-400">Drop</span><span class="font-mono font-semibold">F</span></div>
          <div class="flex justify-between"><span class="text-zinc-400">Inspect</span><span class="font-mono font-semibold">Q</span></div>
          <div class="flex justify-between"><span class="text-zinc-400">Medi-Shot</span><span class="font-mono font-semibold">H</span></div>
          <div class="flex justify-between"><span class="text-zinc-400">HE Grenade</span><span class="font-mono font-semibold">6 / G</span></div>
          <div class="flex justify-between"><span class="text-zinc-400">Flash</span><span class="font-mono font-semibold">7 / C</span></div>
          <div class="flex justify-between"><span class="text-zinc-400">Smoke</span><span class="font-mono font-semibold">8 / X</span></div>
          <div class="flex justify-between"><span class="text-zinc-400">Molotov</span><span class="font-mono font-semibold">0 / Z</span></div>
          <div class="flex justify-between"><span class="text-zinc-400">Decoy</span><span class="font-mono font-semibold">9 / O</span></div>
          <div class="flex justify-between"><span class="text-zinc-400">Voice</span><span class="font-mono font-semibold">V</span></div>
          <div class="flex justify-between"><span class="text-zinc-400">Team Chat</span><span class="font-mono font-semibold">U</span></div>
          <div class="flex justify-between"><span class="text-zinc-400">All Chat</span><span class="font-mono font-semibold">Y</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Matches -->
  <section id="matches" class="py-20" style="background: var(--bg-secondary);">
    <div class="max-w-6xl mx-auto px-5">
      <h2 class="section-title reveal">Recent Matches</h2>
      <div class="glass-card reveal stagger-1">
        <MatchHistory client:load apiUrl={API} />
      </div>
    </div>
  </section>
</MainLayout>
