---
const socials = [
  { label: 'Steam', href: 'https://steamcommunity.com/id/pmec', icon: '🎮' },
  { label: 'FACEIT', href: 'https://www.faceit.com/en/players/pmec', icon: '🎯' },
  { label: 'Twitch', href: 'https://www.twitch.tv/pmec', icon: '📺' },
  { label: 'Twitter', href: 'https://twitter.com/pmec', icon: '🐦' },
  { label: 'Settings', href: 'https://settings.gg/pmec/cs2', icon: '⚙️' },
];
---

<footer class="border-t border-white/10 mt-20" style="background: rgba(15,15,35,0.6);">
  <div class="max-w-6xl mx-auto px-5 py-10 flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="text-center md:text-left">
      <span class="text-gradient font-bold text-lg">Statsmec</span>
      <p class="text-zinc-500 text-sm mt-1">CS2 stats & progress tracker for pmec</p>
    </div>
    <div class="flex gap-4">
      {socials.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noreferrer"
          title={s.label}
          class="w-10 h-10 flex items-center justify-center rounded-full border border-white/10 text-base hover:bg-primary-600 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary-500/30 transition-all"
        >
          {s.icon}
        </a>
      ))}
    </div>
    <p class="text-zinc-600 text-xs">&copy; {new Date().getFullYear()} pmec. Built with Astro + Svelte.</p>
  </div>
</footer>
